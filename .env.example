# Twitch AssistMe — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Twitch application Client ID (from https://dev.twitch.tv/console/apps)
TWITCH_AISSISTME_CLIENT_ID=

# Twitch Client Secret — enables Authorization Code flow (confidential client).
# If unset, the app falls back to Device Code Grant Flow (no secret needed).
TWITCH_AISSISTME_SECRET_KEY=
