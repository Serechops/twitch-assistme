# Twitch AssistMe — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.
#
# END USERS: You do NOT need this file. The app works out of the box.
#
# DEVELOPERS: If you want to use the Authorization Code flow (confidential
# client) instead of the default Device Code Grant Flow, set your secret here.
# Get it from https://dev.twitch.tv/console/apps after setting app to "Confidential".
TWITCH_AISSISTME_SECRET_KEY=
