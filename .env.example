# Twitch AssistMe — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Optional: Twitch Client Secret for Authorization Code flow (confidential client).
# If unset, the app falls back to Device Code Grant Flow (no secret needed).
# Get this from https://dev.twitch.tv/console/apps after setting your app to "Confidential".
TWITCH_CLIENT_SECRET=
